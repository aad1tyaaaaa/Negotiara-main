generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                String
  email               String        @unique
  password            String
  role                Role          @default(SHIPPER)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @default(now()) @updatedAt
  carriedNegotiations Negotiation[] @relation("CarrierNegotiations")
  shippedNegotiations Negotiation[] @relation("ShipperNegotiations")
}

model Shipment {
  id           String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  origin       String
  destination  String
  distance     Float?
  cargoType    String
  weight       Float
  deadline     DateTime
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  negotiations Negotiation[]
}

model Negotiation {
  id              String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  shipmentId      String
  shipperId       String
  carrierId       String?
  status          NegotiationStatus @default(OPEN)
  basePrice       Float
  targetPrice     Float
  shipperBudget   Float?
  carrierMinPrice Float?
  strategyProfile String?
  operationalCost Float?
  desiredMargin   Float?
  intrinsicValue  Float?
  marketBenchmark Float?
  deadline        DateTime
  maxRounds       Int               @default(5)
  currentRound    Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
  carrier         User?             @relation("CarrierNegotiations", fields: [carrierId], references: [id])
  shipment        Shipment          @relation(fields: [shipmentId], references: [id])
  shipper         User              @relation("ShipperNegotiations", fields: [shipperId], references: [id])
  offers          Offer[]

  @@index([shipperId])
  @@index([carrierId])
  @@index([status])
}

model Offer {
  id             String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  negotiationId  String
  round          Int
  price          Float
  senderId       String
  strategy       String?
  reasoning      String?
  shipperUtility Float?
  carrierUtility Float?
  message        String?
  createdAt      DateTime    @default(now())
  negotiation    Negotiation @relation(fields: [negotiationId], references: [id])

  @@index([negotiationId])
}

enum Role {
  SHIPPER
  CARRIER
  ADMIN
}

enum NegotiationStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  WALK_AWAY
}
